generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  admin
  me_officer
  data_collector
  viewer
}

enum ReportingFrequency {
  quarterly
  annual
}

enum ReportingPeriod {
  Q1
  Q2
  Q3
  Q4
  Annual
}

enum SubmissionStatus {
  draft
  submitted
  pending_supervisor
  pending_me
  approved
  rejected
}

enum FormulaType {
  achievement_pct
  cumulative_total
  proportion_pct
  complement_pct
  multi_input
  manual
}

enum OwnerType {
  Institution
  Department
  Unit
}

model Institution {
  id            String   @id @default(uuid())
  name          String
  code          String   @unique
  region        String?
  contactEmail  String?
  apiKey        String   @unique @default(uuid())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users               User[]
  indicatorTargets    IndicatorTarget[]
  indicatorActuals    IndicatorActual[]
  budgetPlans         BudgetPlan[]
  expenditures        Expenditure[]
  formSubmissions     FormSubmission[]
  itemizedBudgets     ItemizedBudget[]
  strategicObjectives StrategicObjective[]
  projects            Project[]
  assignedActivities  Activity[] @relation("ActivityInstitution")
  objectiveResponsibles ObjectiveResponsible[]
  ownedIndicators    Indicator[] @relation("IndicatorOwnerInstitution")
  apiKeys            ApiKey[]
  syncLogs           ApiSyncLog[]
  documents          Document[]

  @@map("institutions")
}

model User {
  id             String      @id @default(uuid())
  institutionId  String?
  departmentId   String?
  unitId         String?
  name           String
  email          String      @unique
  passwordHash   String
  role           Role
  isActive            Boolean     @default(true)
  failedLoginAttempts Int         @default(0)
  lockedUntil         DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  institution         Institution?        @relation(fields: [institutionId], references: [id])
  department          Department?         @relation(fields: [departmentId], references: [id])
  unit                Unit?               @relation(fields: [unitId], references: [id])
  refreshTokens       RefreshToken[]
  submittedActuals    IndicatorActual[]   @relation("SubmittedBy")
  approvedActuals     IndicatorActual[]   @relation("ApprovedBy")
  supervisedActuals   IndicatorActual[]   @relation("SupervisedBy")
  submittedExpenses   Expenditure[]       @relation("ExpSubmittedBy")
  approvedExpenses    Expenditure[]       @relation("ExpApprovedBy")
  formSubmissions     FormSubmission[]
  createdIndicators   Indicator[]
  auditLogs           AuditLog[]
  createdProjects     Project[]
  createdApiKeys      ApiKey[]            @relation("ApiKeyCreatedBy")
  notifications       Notification[]
  submissionComments  SubmissionComment[]
  uploadedDocuments   Document[]
  periodLocks         ReportingPeriodLock[]
  calendarEntries     ReportingCalendar[]
  frameworkVersionsCreated  FrameworkVersion[] @relation("FVCreatedBy")
  frameworkVersionsApproved FrameworkVersion[] @relation("FVApprovedBy")
  submittedTickets          SupportTicket[]    @relation("TicketSubmittedBy")
  assignedTickets           SupportTicket[]    @relation("TicketAssignedTo")
  ticketReplies             TicketReply[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model StrategicObjective {
  id            String   @id @default(uuid())
  name          String
  description   String?
  orderNo       Int      @default(0)
  weight        Float    @default(1.0)
  institutionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution  Institution?          @relation(fields: [institutionId], references: [id])
  responsibles ObjectiveResponsible[]
  outcomes     Outcome[]

  @@map("strategic_objectives")
}

model Outcome {
  id          String   @id @default(uuid())
  objectiveId String
  name        String
  description String?
  orderNo     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  objective StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  outputs   Output[]

  @@map("outcomes")
}

model Output {
  id          String   @id @default(uuid())
  outcomeId   String
  name        String
  description String?
  orderNo     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outcome     Outcome    @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  activities  Activity[]
  indicators  Indicator[]

  @@map("outputs")
}

model Activity {
  id                       String         @id @default(uuid())
  outputId                 String
  name                     String
  description              String?
  orderNo                  Int            @default(0)
  weight                   Float          @default(1.0)
  isCritical               Boolean        @default(false)
  responsibleInstitutionId String?
  responsibleDepartmentId  String?
  responsibleUnitId        String?
  // Workplan fields
  startDate                DateTime?
  endDate                  DateTime?
  progressPct              Float          @default(0)
  workplanStatus           WorkplanStatus @default(not_started)
  remarks                  String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  output                 Output        @relation(fields: [outputId], references: [id], onDelete: Cascade)
  responsibleInstitution Institution?  @relation("ActivityInstitution", fields: [responsibleInstitutionId], references: [id])
  responsibleDepartment  Department?   @relation("ActivityDepartment", fields: [responsibleDepartmentId], references: [id])
  responsibleUnit        Unit?         @relation("ActivityUnit", fields: [responsibleUnitId], references: [id])
  budgetPlans            BudgetPlan[]
  actuals                IndicatorActual[]
  milestones             ActivityMilestone[]

  @@map("activities")
}

model ActivityMilestone {
  id          String         @id @default(uuid())
  activityId  String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      WorkplanStatus @default(not_started)
  orderNo     Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("activity_milestones")
}

model Indicator {
  id                  String             @id @default(uuid())
  outputId            String
  name                String
  code                String             @unique
  unit                String
  dataSource          String?
  formulaType         FormulaType        @default(achievement_pct)
  formulaConfig       Json?
  responsiblePerson   String?
  reportingFrequency  ReportingFrequency @default(quarterly)
  baselineValue       Float?
  baselineYear        Int?
  createdById         String
  isActive            Boolean            @default(true)
  ownerType           OwnerType?
  ownerInstitutionId  String?
  ownerDepartmentId   String?
  ownerUnitId         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  output    Output    @relation(fields: [outputId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
  ownerInstitution    Institution? @relation("IndicatorOwnerInstitution", fields: [ownerInstitutionId], references: [id])
  ownerDepartment     Department?  @relation("IndicatorOwnerDept",        fields: [ownerDepartmentId],  references: [id])
  ownerUnit           Unit?        @relation("IndicatorOwnerUnit",         fields: [ownerUnitId],        references: [id])

  targets  IndicatorTarget[]
  actuals  IndicatorActual[]
  forms    DataForm[]

  @@map("indicators")
}

model IndicatorTarget {
  id             String @id @default(uuid())
  indicatorId    String
  institutionId  String
  fiscalYear     String
  q1Target       Float?
  q2Target       Float?
  q3Target       Float?
  q4Target       Float?
  annualTarget   Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  indicator   Indicator   @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id])

  @@unique([indicatorId, institutionId, fiscalYear])
  @@map("indicator_targets")
}

model IndicatorActual {
  id              String           @id @default(uuid())
  indicatorId     String
  activityId      String?
  institutionId   String
  departmentId    String?
  unitId          String?
  fiscalYear      String
  reportingPeriod ReportingPeriod
  actualValue     Float?
  extraFields     Json?
  submittedById   String
  submittedAt     DateTime         @default(now())
  status          SubmissionStatus @default(draft)
  supervisedById  String?
  supervisedAt    DateTime?
  supervisorNote  String?
  approvedById    String?
  approvedAt      DateTime?
  remarks         String?
  attachments     String[]         @default([])
  updatedAt       DateTime         @updatedAt

  indicator   Indicator   @relation(fields: [indicatorId], references: [id])
  activity    Activity?   @relation(fields: [activityId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  unit        Unit?       @relation(fields: [unitId], references: [id])
  submittedBy  User        @relation("SubmittedBy",   fields: [submittedById],  references: [id])
  supervisedBy User?       @relation("SupervisedBy",  fields: [supervisedById], references: [id])
  approvedBy   User?       @relation("ApprovedBy",    fields: [approvedById],   references: [id])
  comments     SubmissionComment[]

  @@unique([indicatorId, institutionId, fiscalYear, reportingPeriod])
  @@map("indicator_actuals")
}

model BudgetPlan {
  id            String   @id @default(uuid())
  activityId    String
  institutionId String
  fiscalYear    String
  q1Budget      Float    @default(0)
  q2Budget      Float    @default(0)
  q3Budget      Float    @default(0)
  q4Budget      Float    @default(0)
  totalBudget   Float    @default(0)
  fundingSource String?
  currency      String   @default("TZS")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activity     Activity      @relation(fields: [activityId], references: [id])
  institution  Institution   @relation(fields: [institutionId], references: [id])
  expenditures Expenditure[]

  @@unique([activityId, institutionId, fiscalYear])
  @@map("budget_plans")
}

model Expenditure {
  id            String           @id @default(uuid())
  budgetPlanId  String
  institutionId String
  period        ReportingPeriod
  amount        Float
  description   String?
  evidenceUrl   String?
  submittedById String
  status        SubmissionStatus @default(draft)
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  budgetPlan  BudgetPlan  @relation(fields: [budgetPlanId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])
  submittedBy User        @relation("ExpSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?       @relation("ExpApprovedBy", fields: [approvedById], references: [id])

  @@map("expenditures")
}

model DataForm {
  id          String   @id @default(uuid())
  name        String
  indicatorId String
  fields      Json
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  indicator   Indicator        @relation(fields: [indicatorId], references: [id])
  submissions FormSubmission[]

  @@map("data_forms")
}

model FormSubmission {
  id            String           @id @default(uuid())
  formId        String
  institutionId String
  submittedById String
  data          Json
  period        ReportingPeriod
  fiscalYear    String
  status        SubmissionStatus @default(draft)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  form        DataForm    @relation(fields: [formId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])
  submittedBy User        @relation(fields: [submittedById], references: [id])

  @@map("form_submissions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  tableName  String
  recordId   String?
  changes    Json?
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Department {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  orderNo     Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units                 Unit[]
  users                 User[]
  budgetItems           ItemizedBudget[]
  actuals               IndicatorActual[]
  projects              Project[]
  assignedActivities    Activity[]            @relation("ActivityDepartment")
  objectiveResponsibles ObjectiveResponsible[]
  ownedIndicators    Indicator[] @relation("IndicatorOwnerDept")
  documents          Document[]

  @@map("departments")
}

model Unit {
  id           String   @id @default(uuid())
  departmentId String
  name         String
  code         String   @unique
  description  String?
  orderNo      Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department            Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  users                 User[]
  budgetItems           ItemizedBudget[]
  actuals               IndicatorActual[]
  projects              Project[]
  assignedActivities    Activity[]            @relation("ActivityUnit")
  objectiveResponsibles ObjectiveResponsible[]
  ownedIndicators    Indicator[] @relation("IndicatorOwnerUnit")
  documents          Document[]

  @@map("units")
}

model ItemizedBudget {
  id                   String   @id @default(uuid())
  accountCode          String
  accountDescription   String
  accountClass         String?
  departmentId         String?
  unitId               String?
  institutionId        String?
  fiscalYear           String
  period               String
  budgetA              Float    @default(0)
  fundAllocationB      Float    @default(0)
  expenditurePrevMonth Float    @default(0)
  expenditureThisMonth Float    @default(0)
  expenditureToDate    Float    @default(0)
  commitmentToDate     Float    @default(0)
  totalCommitExpendC   Float    @default(0)
  fundBalanceBC        Float    @default(0)
  budgetBalanceAB      Float    @default(0)
  isOtherCharges       Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  department  Department?  @relation(fields: [departmentId], references: [id])
  unit        Unit?        @relation(fields: [unitId], references: [id])
  institution Institution? @relation(fields: [institutionId], references: [id])

  @@map("itemized_budgets")
}

model IndustryStatistics {
  id              String   @id @default(uuid())
  fiscalYear      String
  period          String
  totalRegistered Int      @default(0)
  operating       Int      @default(0)
  closed          Int      @default(0)
  newRegistered   Int      @default(0)
  region          String?
  sector          String?
  reportDate      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("industry_statistics")
}

enum WorkplanStatus {
  not_started
  in_progress
  completed
  delayed
  on_hold
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum ProjectStatus {
  planned
  ongoing
  completed
  delayed
  cancelled
}

enum MilestoneStatus {
  not_started
  ongoing
  completed
  delayed
}

model Project {
  id            String        @id @default(uuid())
  name          String
  code          String?       @unique
  goal          String?
  description   String?
  institutionId String?
  departmentId  String?
  unitId        String?
  status        ProjectStatus @default(planned)
  startDate     DateTime?
  endDate       DateTime?
  totalBudget   Float         @default(0)
  fiscalYear    String        @default("2025-2026")
  fundingSource String?
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  institution   Institution? @relation(fields: [institutionId], references: [id])
  department    Department?  @relation(fields: [departmentId],  references: [id])
  unit          Unit?        @relation(fields: [unitId],        references: [id])
  createdBy     User?        @relation(fields: [createdById],   references: [id])
  milestones    ProjectMilestone[]
  activities    ProjectActivity[]
  expenditures  ProjectExpenditure[]

  @@map("projects")
}

model ProjectMilestone {
  id          String          @id @default(uuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      MilestoneStatus @default(not_started)
  orderNo     Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_milestones")
}

model ProjectActivity {
  id          String    @id @default(uuid())
  projectId   String
  name        String
  description String?
  responsible String?
  dueDate     DateTime?
  completedAt DateTime?
  isCompleted Boolean   @default(false)
  orderNo     Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_activities")
}

model ProjectExpenditure {
  id          String   @id @default(uuid())
  projectId   String
  amount      Float
  description String?
  period      String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_expenditures")
}

model ObjectiveResponsible {
  id            String   @id @default(uuid())
  objectiveId   String
  institutionId String?
  departmentId  String?
  unitId        String?
  createdAt     DateTime @default(now())

  objective   StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  institution Institution? @relation(fields: [institutionId], references: [id])
  department  Department?  @relation(fields: [departmentId], references: [id])
  unit        Unit?        @relation(fields: [unitId], references: [id])

  @@map("objective_responsibles")
}

model ApiKey {
  id            String    @id @default(uuid())
  institutionId String
  label         String
  keyHash       String    @unique
  keyPrefix     String
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])
  createdBy   User        @relation("ApiKeyCreatedBy", fields: [createdById], references: [id])
  syncLogs    ApiSyncLog[]

  @@map("api_keys")
}

model ApiSyncLog {
  id            String   @id @default(uuid())
  apiKeyId      String
  institutionId String
  endpoint      String
  method        String   @default("POST")
  statusCode    Int
  recordCount   Int      @default(1)
  errorMessage  String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  apiKey      ApiKey      @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id])

  @@map("api_sync_logs")
}

// ── Reporting Period Lock ──────────────────────────────────────────────────────
model ReportingPeriodLock {
  id          String          @id @default(uuid())
  fiscalYear  String
  period      ReportingPeriod
  isLocked    Boolean         @default(false)
  lockedById  String?
  lockedAt    DateTime?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  lockedBy    User?           @relation(fields: [lockedById], references: [id])

  @@unique([fiscalYear, period])
  @@map("reporting_period_locks")
}

// ── Reporting Calendar ────────────────────────────────────────────────────────
model ReportingCalendar {
  id           String          @id @default(uuid())
  fiscalYear   String
  period       ReportingPeriod
  startDate    DateTime
  deadline     DateTime
  reminderDays Int             @default(7)
  isActive     Boolean         @default(true)
  description  String?
  createdById  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  createdBy    User?           @relation(fields: [createdById], references: [id])

  @@unique([fiscalYear, period])
  @@map("reporting_calendars")
}

// ── Submission Comments ───────────────────────────────────────────────────────
model SubmissionComment {
  id         String   @id @default(uuid())
  actualId   String
  userId     String
  comment    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  actual IndicatorActual @relation(fields: [actualId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id])

  @@map("submission_comments")
}

// ── Notifications ─────────────────────────────────────────────────────────────
model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  relatedType String?
  relatedId   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── Documents ─────────────────────────────────────────────────────────────────
model Document {
  id            String   @id @default(uuid())
  name          String
  description   String?
  fileUrl       String
  fileName      String
  fileSize      Int?
  mimeType      String?
  category      String   @default("general")
  fiscalYear    String?
  period        String?
  institutionId String?
  departmentId  String?
  unitId        String?
  tags          String[] @default([])
  uploadedById  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  uploadedBy  User         @relation(fields: [uploadedById], references: [id])
  institution Institution? @relation(fields: [institutionId], references: [id])
  department  Department?  @relation(fields: [departmentId], references: [id])
  unit        Unit?        @relation(fields: [unitId], references: [id])

  @@map("documents")
}

// ── Support Helpdesk ─────────────────────────────────────────────────────────
model SupportTicket {
  id            String         @id @default(uuid())
  ticketNo      String         @unique
  subject       String
  description   String
  category      String         @default("general")
  priority      TicketPriority @default(medium)
  status        TicketStatus   @default(open)
  submittedById String?
  guestName     String?
  guestEmail    String?
  assignedToId  String?
  institutionId String?
  resolvedAt    DateTime?
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  submittedBy User?        @relation("TicketSubmittedBy", fields: [submittedById], references: [id])
  assignedTo  User?        @relation("TicketAssignedTo",  fields: [assignedToId],  references: [id])
  replies     TicketReply[]

  @@map("support_tickets")
}

model TicketReply {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String
  message    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@map("ticket_replies")
}

// ── Framework Versions ────────────────────────────────────────────────────────
model FrameworkVersion {
  id           String   @id @default(uuid())
  versionLabel String
  fiscalYear   String
  description  String?
  snapshot     Json
  isActive     Boolean  @default(false)
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy  User  @relation("FVCreatedBy",  fields: [createdById],  references: [id])
  approvedBy User? @relation("FVApprovedBy", fields: [approvedById], references: [id])

  @@map("framework_versions")
}
