generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  admin
  me_officer
  data_collector
  viewer
}

enum ReportingFrequency {
  quarterly
  annual
}

enum ReportingPeriod {
  Q1
  Q2
  Q3
  Q4
  Annual
}

enum SubmissionStatus {
  draft
  submitted
  pending_supervisor
  pending_me
  approved
  rejected
}

enum FormulaType {
  achievement_pct
  cumulative_total
  proportion_pct
  complement_pct
  multi_input
  manual
  yoy_growth
  weighted_score
  cost_per_output
  ppt_change
  binary
  rate_per_n
  average_value
}

enum OwnerType {
  Institution
  Department
  Unit
}

enum IndicatorType {
  output_indicator
  outcome_indicator
  impact_indicator
  process_indicator
}

enum ProgressDirection {
  increasing
  decreasing
  stable
}

enum IndicatorStatus {
  active
  discontinued
  under_revision
  retired
}

model Institution {
  id            String   @id @default(uuid())
  name          String
  code          String   @unique
  region        String?
  contactEmail  String?
  apiKey        String   @unique @default(uuid())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users               User[]
  indicatorTargets    IndicatorTarget[]
  indicatorActuals    IndicatorActual[]
  budgetPlans         BudgetPlan[]
  mtefBudgets         MtefBudget[]
  expenditures        Expenditure[]
  formSubmissions     FormSubmission[]
  itemizedBudgets     ItemizedBudget[]
  strategicObjectives StrategicObjective[]
  projects            Project[]
  assignedActivities  Activity[] @relation("ActivityInstitution")
  objectiveResponsibles ObjectiveResponsible[]
  ownedIndicators    Indicator[] @relation("IndicatorOwnerInstitution")
  apiKeys            ApiKey[]
  syncLogs           ApiSyncLog[]
  documents          Document[]
  customFormResponses CustomFormResponse[]
  swotEntries         SwotEntry[]
  systemInsights      SystemInsight[]

  @@map("institutions")
}

model User {
  id             String      @id @default(uuid())
  institutionId  String?
  departmentId   String?
  unitId         String?
  name           String
  email          String      @unique
  passwordHash   String
  role           Role
  isActive            Boolean     @default(true)
  failedLoginAttempts Int         @default(0)
  lockedUntil         DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  // 2FA
  twoFactorSecret   String?
  twoFactorEnabled  Boolean  @default(false)
  // Contact
  phoneNumber       String?
  // SSO
  ssoProvider       String?
  ssoId             String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  institution         Institution?        @relation(fields: [institutionId], references: [id])
  department          Department?         @relation(fields: [departmentId], references: [id])
  unit                Unit?               @relation(fields: [unitId], references: [id])
  refreshTokens       RefreshToken[]
  submittedActuals    IndicatorActual[]   @relation("SubmittedBy")
  approvedActuals     IndicatorActual[]   @relation("ApprovedBy")
  supervisedActuals   IndicatorActual[]   @relation("SupervisedBy")
  submittedExpenses   Expenditure[]       @relation("ExpSubmittedBy")
  approvedExpenses    Expenditure[]       @relation("ExpApprovedBy")
  formSubmissions     FormSubmission[]
  createdIndicators   Indicator[]
  auditLogs           AuditLog[]
  createdProjects     Project[]
  createdApiKeys      ApiKey[]            @relation("ApiKeyCreatedBy")
  notifications       Notification[]
  submissionComments  SubmissionComment[]
  uploadedDocuments   Document[]
  periodLocks         ReportingPeriodLock[]
  calendarEntries     ReportingCalendar[]
  frameworkVersionsCreated  FrameworkVersion[] @relation("FVCreatedBy")
  frameworkVersionsApproved FrameworkVersion[] @relation("FVApprovedBy")
  submittedTickets          SupportTicket[]    @relation("TicketSubmittedBy")
  assignedTickets           SupportTicket[]    @relation("TicketAssignedTo")
  ticketReplies             TicketReply[]
  tocCreated                TheoryOfChange[]
  customFormsCreated        CustomForm[]
  customFormResponses       CustomFormResponse[]
  swotEntries               SwotEntry[]
  reviewedRequests          UserRequest[]  @relation("RequestReviewedBy")
  pushSubscriptions         PushSubscription[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model StrategicObjective {
  id            String   @id @default(uuid())
  code          String?
  name          String
  description   String?
  orderNo       Int      @default(0)
  weight        Float    @default(1.0)
  institutionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution  Institution?          @relation(fields: [institutionId], references: [id])
  responsibles ObjectiveResponsible[]
  outcomes     Outcome[]

  @@map("strategic_objectives")
}

model Outcome {
  id          String   @id @default(uuid())
  objectiveId String
  code        String?
  name        String
  description String?
  orderNo     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  objective StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  outputs   Output[]

  @@map("outcomes")
}

model Output {
  id          String   @id @default(uuid())
  outcomeId   String
  name        String
  description String?
  orderNo     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outcome     Outcome    @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  activities  Activity[]
  indicators  Indicator[]

  @@map("outputs")
}

model Activity {
  id                       String         @id @default(uuid())
  outputId                 String
  code                     String?
  name                     String
  description              String?
  orderNo                  Int            @default(0)
  weight                   Float          @default(1.0)
  isCritical               Boolean        @default(false)
  responsibleInstitutionId String?
  responsibleDepartmentId  String?
  responsibleUnitId        String?
  // Workplan fields
  startDate                DateTime?
  endDate                  DateTime?
  progressPct              Float          @default(0)
  workplanStatus           WorkplanStatus @default(not_started)
  remarks                  String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  output                 Output        @relation(fields: [outputId], references: [id], onDelete: Cascade)
  responsibleInstitution Institution?  @relation("ActivityInstitution", fields: [responsibleInstitutionId], references: [id])
  responsibleDepartment  Department?   @relation("ActivityDepartment", fields: [responsibleDepartmentId], references: [id])
  responsibleUnit        Unit?         @relation("ActivityUnit", fields: [responsibleUnitId], references: [id])
  budgetPlans            BudgetPlan[]
  mtefBudgets            MtefBudget[]
  actuals                IndicatorActual[]
  milestones             ActivityMilestone[]
  activityToIndicatorMappings ActivityIndicatorMapping[] @relation("ActivityToIndicatorMappings")

  @@map("activities")
}

model ActivityMilestone {
  id          String         @id @default(uuid())
  activityId  String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      WorkplanStatus @default(not_started)
  orderNo     Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("activity_milestones")
}

model Indicator {
  id                  String             @id @default(uuid())
  outputId            String
  name                String
  code                String             @unique
  unit                String
  dataSource          String?
  formulaType         FormulaType        @default(achievement_pct)
  formulaConfig       Json?
  responsiblePerson   String?
  reportingFrequency  ReportingFrequency @default(quarterly)
  baselineValue       Float?
  baselineYear        Int?
  createdById         String
  isActive            Boolean            @default(true)
  indicatorType      IndicatorType?
  progressDirection  ProgressDirection @default(increasing)
  indicatorStatus    IndicatorStatus   @default(active)
  minValue           Float?
  maxValue           Float?
  collectionMethod   String?
  verificationSource String?
  description        String?
  ownerType           OwnerType?
  ownerInstitutionId  String?
  ownerDepartmentId   String?
  ownerUnitId         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  output    Output    @relation(fields: [outputId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
  ownerInstitution    Institution? @relation("IndicatorOwnerInstitution", fields: [ownerInstitutionId], references: [id])
  ownerDepartment     Department?  @relation("IndicatorOwnerDept",        fields: [ownerDepartmentId],  references: [id])
  ownerUnit           Unit?        @relation("IndicatorOwnerUnit",         fields: [ownerUnitId],        references: [id])

  targets  IndicatorTarget[]
  actuals  IndicatorActual[]
  disaggregatedActuals ActualDisaggregation[]
  forms    DataForm[]
  insights SystemInsight[]
  activityToIndicatorMappings ActivityIndicatorMapping[] @relation("IndicatorToActivityMappings")
  performanceData PerformanceData[] @relation("IndicatorPerformanceData")
  calculationRules IndicatorCalculationRule[] @relation("IndicatorCalculationRules")

  @@map("indicators")
}

model IndicatorTarget {
  id             String @id @default(uuid())
  indicatorId    String
  institutionId  String
  fiscalYear     String
  q1Target       Float?
  q2Target       Float?
  q3Target       Float?
  q4Target       Float?
  annualTarget   Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  indicator   Indicator   @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id])

  @@unique([indicatorId, institutionId, fiscalYear])
  @@map("indicator_targets")
}

model IndicatorActual {
  id              String           @id @default(uuid())
  indicatorId     String
  activityId      String?
  institutionId   String
  departmentId    String?
  unitId          String?
  fiscalYear      String
  reportingPeriod ReportingPeriod
  actualValue     Float?
  extraFields     Json?
  // GPS coordinates captured at submission time
  latitude        Float?
  longitude       Float?
  locationName    String?
  submittedById   String
  submittedAt     DateTime         @default(now())
  status          SubmissionStatus @default(draft)
  supervisedById  String?
  supervisedAt    DateTime?
  supervisorNote  String?
  approvedById    String?
  approvedAt      DateTime?
  remarks         String?
  rejectionReason    String?
  supervisorReason   String?
  disaggregations    ActualDisaggregation[]
  attachments     String[]         @default([])
  updatedAt       DateTime         @updatedAt

  indicator   Indicator   @relation(fields: [indicatorId], references: [id])
  activity    Activity?   @relation(fields: [activityId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  unit        Unit?       @relation(fields: [unitId], references: [id])
  submittedBy  User        @relation("SubmittedBy",   fields: [submittedById],  references: [id])
  supervisedBy User?       @relation("SupervisedBy",  fields: [supervisedById], references: [id])
  approvedBy   User?       @relation("ApprovedBy",    fields: [approvedById],   references: [id])
  comments     SubmissionComment[]
  insights     SystemInsight[]

  @@unique([indicatorId, institutionId, fiscalYear, reportingPeriod])
  // Performance indexes for the most common listActuals query patterns
  @@index([institutionId, fiscalYear, status])
  @@index([status, fiscalYear])
  @@index([fiscalYear, reportingPeriod])
  @@index([submittedById])
  @@map("indicator_actuals")
}

model BudgetPlan {
  id            String   @id @default(uuid())
  activityId    String
  institutionId String
  fiscalYear    String
  q1Budget      Float    @default(0)
  q2Budget      Float    @default(0)
  q3Budget      Float    @default(0)
  q4Budget      Float    @default(0)
  totalBudget   Float    @default(0)
  fundingSource String?
  currency      String   @default("TZS")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activity     Activity      @relation(fields: [activityId], references: [id])
  institution  Institution   @relation(fields: [institutionId], references: [id])
  expenditures Expenditure[]

  @@unique([activityId, institutionId, fiscalYear])
  @@map("budget_plans")
}

model Expenditure {
  id            String           @id @default(uuid())
  budgetPlanId  String
  institutionId String
  period        ReportingPeriod
  amount        Float
  description   String?
  evidenceUrl   String?
  submittedById String
  status        SubmissionStatus @default(draft)
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  budgetPlan  BudgetPlan  @relation(fields: [budgetPlanId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])
  submittedBy User        @relation("ExpSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?       @relation("ExpApprovedBy", fields: [approvedById], references: [id])

  @@map("expenditures")
}

model DataForm {
  id          String   @id @default(uuid())
  name        String
  indicatorId String
  fields      Json
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  indicator   Indicator        @relation(fields: [indicatorId], references: [id])
  submissions FormSubmission[]

  @@map("data_forms")
}

model FormSubmission {
  id            String           @id @default(uuid())
  formId        String
  institutionId String
  submittedById String
  data          Json
  period        ReportingPeriod
  fiscalYear    String
  status        SubmissionStatus @default(draft)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  form        DataForm    @relation(fields: [formId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])
  submittedBy User        @relation(fields: [submittedById], references: [id])

  @@map("form_submissions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  tableName  String
  recordId   String?
  changes    Json?
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Department {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  orderNo     Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units                 Unit[]
  users                 User[]
  budgetItems           ItemizedBudget[]
  actuals               IndicatorActual[]
  projects              Project[]
  assignedActivities    Activity[]            @relation("ActivityDepartment")
  objectiveResponsibles ObjectiveResponsible[]
  ownedIndicators    Indicator[] @relation("IndicatorOwnerDept")
  documents          Document[]

  @@map("departments")
}

model Unit {
  id           String   @id @default(uuid())
  departmentId String
  name         String
  code         String   @unique
  description  String?
  orderNo      Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department            Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  users                 User[]
  budgetItems           ItemizedBudget[]
  actuals               IndicatorActual[]
  projects              Project[]
  assignedActivities    Activity[]            @relation("ActivityUnit")
  objectiveResponsibles ObjectiveResponsible[]
  ownedIndicators    Indicator[] @relation("IndicatorOwnerUnit")
  documents          Document[]

  @@map("units")
}

model ItemizedBudget {
  id                   String   @id @default(uuid())
  accountCode          String
  accountDescription   String
  accountClass         String?
  departmentId         String?
  unitId               String?
  institutionId        String?
  fiscalYear           String
  period               String
  budgetA              Float    @default(0)
  fundAllocationB      Float    @default(0)
  expenditurePrevMonth Float    @default(0)
  expenditureThisMonth Float    @default(0)
  expenditureToDate    Float    @default(0)
  commitmentToDate     Float    @default(0)
  totalCommitExpendC   Float    @default(0)
  fundBalanceBC        Float    @default(0)
  budgetBalanceAB      Float    @default(0)
  isOtherCharges       Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  department  Department?  @relation(fields: [departmentId], references: [id])
  unit        Unit?        @relation(fields: [unitId], references: [id])
  institution Institution? @relation(fields: [institutionId], references: [id])

  @@map("itemized_budgets")
}

model IndustryStatistics {
  id              String   @id @default(uuid())
  fiscalYear      String
  period          String
  totalRegistered Int      @default(0)
  operating       Int      @default(0)
  closed          Int      @default(0)
  newRegistered   Int      @default(0)
  region          String?
  sector          String?
  reportDate      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("industry_statistics")
}

enum WorkplanStatus {
  not_started
  in_progress
  completed
  delayed
  on_hold
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum ProjectStatus {
  planned
  ongoing
  completed
  delayed
  cancelled
}

enum MilestoneStatus {
  not_started
  ongoing
  completed
  delayed
}

enum SwotCategory {
  strength
  weakness
  opportunity
  threat
}

model Project {
  id            String        @id @default(uuid())
  name          String
  code          String?       @unique
  goal          String?
  description   String?
  institutionId String?
  departmentId  String?
  unitId        String?
  status        ProjectStatus @default(planned)
  startDate     DateTime?
  endDate       DateTime?
  totalBudget   Float         @default(0)
  fiscalYear    String        @default("2025-2026")
  fundingSource String?
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  institution   Institution? @relation(fields: [institutionId], references: [id])
  department    Department?  @relation(fields: [departmentId],  references: [id])
  unit          Unit?        @relation(fields: [unitId],        references: [id])
  createdBy     User?        @relation(fields: [createdById],   references: [id])
  milestones    ProjectMilestone[]
  activities    ProjectActivity[]
  expenditures  ProjectExpenditure[]
  strategicObjectives ProjectStrategicObjective[]
  progressSnapshots ProjectProgressSnapshot[] @relation("ProjectProgressSnapshots")

  @@map("projects")
}

model ProjectMilestone {
  id          String          @id @default(uuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      MilestoneStatus @default(not_started)
  orderNo     Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_milestones")
}

model ProjectActivity {
  id          String    @id @default(uuid())
  projectId   String
  name        String
  description String?
  responsible String?
  dueDate     DateTime?
  completedAt DateTime?
  isCompleted Boolean   @default(false)
  orderNo     Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_activities")
}

model ProjectExpenditure {
  id          String   @id @default(uuid())
  projectId   String
  amount      Float
  description String?
  period      String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_expenditures")
}

model ObjectiveResponsible {
  id            String   @id @default(uuid())
  objectiveId   String
  institutionId String?
  departmentId  String?
  unitId        String?
  createdAt     DateTime @default(now())

  objective   StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  institution Institution? @relation(fields: [institutionId], references: [id])
  department  Department?  @relation(fields: [departmentId], references: [id])
  unit        Unit?        @relation(fields: [unitId], references: [id])

  @@map("objective_responsibles")
}

model ApiKey {
  id            String    @id @default(uuid())
  institutionId String
  label         String
  keyHash       String    @unique
  keyPrefix     String
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])
  createdBy   User        @relation("ApiKeyCreatedBy", fields: [createdById], references: [id])
  syncLogs    ApiSyncLog[]

  @@map("api_keys")
}

model ApiSyncLog {
  id            String   @id @default(uuid())
  apiKeyId      String
  institutionId String
  endpoint      String
  method        String   @default("POST")
  statusCode    Int
  recordCount   Int      @default(1)
  errorMessage  String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  apiKey      ApiKey      @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id])

  @@map("api_sync_logs")
}

// ── Reporting Period Lock ──────────────────────────────────────────────────────
model ReportingPeriodLock {
  id          String          @id @default(uuid())
  fiscalYear  String
  period      ReportingPeriod
  isLocked    Boolean         @default(false)
  lockedById  String?
  lockedAt    DateTime?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  lockedBy    User?           @relation(fields: [lockedById], references: [id])

  @@unique([fiscalYear, period])
  @@map("reporting_period_locks")
}

// ── Reporting Calendar ────────────────────────────────────────────────────────
model ReportingCalendar {
  id           String          @id @default(uuid())
  fiscalYear   String
  period       ReportingPeriod
  startDate    DateTime
  deadline     DateTime
  reminderDays Int             @default(7)
  isActive     Boolean         @default(true)
  description  String?
  createdById  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  createdBy    User?           @relation(fields: [createdById], references: [id])

  @@unique([fiscalYear, period])
  @@map("reporting_calendars")
}

// ── Submission Comments ───────────────────────────────────────────────────────
model SubmissionComment {
  id         String   @id @default(uuid())
  actualId   String
  userId     String
  comment    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  actual IndicatorActual @relation(fields: [actualId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id])

  @@map("submission_comments")
}

// ── Notifications ─────────────────────────────────────────────────────────────
model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  relatedType String?
  relatedId   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── Documents ─────────────────────────────────────────────────────────────────
model Document {
  id            String   @id @default(uuid())
  name          String
  description   String?
  fileUrl       String
  fileName      String
  fileSize      Int?
  mimeType      String?
  category      String   @default("general")
  fiscalYear    String?
  period        String?
  institutionId String?
  departmentId  String?
  unitId        String?
  tags          String[] @default([])
  uploadedById  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  uploadedBy  User         @relation(fields: [uploadedById], references: [id])
  institution Institution? @relation(fields: [institutionId], references: [id])
  department  Department?  @relation(fields: [departmentId], references: [id])
  unit        Unit?        @relation(fields: [unitId], references: [id])

  @@map("documents")
}

// ── Support Helpdesk ─────────────────────────────────────────────────────────
model SupportTicket {
  id            String         @id @default(uuid())
  ticketNo      String         @unique
  subject       String
  description   String
  category      String         @default("general")
  priority      TicketPriority @default(medium)
  status        TicketStatus   @default(open)
  submittedById String?
  guestName     String?
  guestEmail    String?
  assignedToId  String?
  institutionId String?
  resolvedAt    DateTime?
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  submittedBy User?        @relation("TicketSubmittedBy", fields: [submittedById], references: [id])
  assignedTo  User?        @relation("TicketAssignedTo",  fields: [assignedToId],  references: [id])
  replies     TicketReply[]

  @@map("support_tickets")
}

model TicketReply {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String
  message    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@map("ticket_replies")
}

// ── Framework Versions ────────────────────────────────────────────────────────
model FrameworkVersion {
  id           String   @id @default(uuid())
  versionLabel String
  fiscalYear   String
  description  String?
  snapshot     Json
  isActive     Boolean  @default(false)
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy  User  @relation("FVCreatedBy",  fields: [createdById],  references: [id])
  approvedBy User? @relation("FVApprovedBy", fields: [approvedById], references: [id])

  @@map("framework_versions")
}

// ── Disaggregation Framework ──────────────────────────────────────────────────
model Disaggregation {
  id          String   @id @default(uuid())
  name        String
  description String?
  isGlobal    Boolean  @default(true)
  isRequired  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  options DisaggregationOption[]
  actuals ActualDisaggregation[]

  @@map("disaggregations")
}

model DisaggregationOption {
  id               String         @id @default(uuid())
  disaggregationId String
  label            String
  code             String?
  orderNo          Int            @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())

  disaggregation Disaggregation         @relation(fields: [disaggregationId], references: [id], onDelete: Cascade)
  actuals        ActualDisaggregation[]

  @@unique([disaggregationId, label])
  @@map("disaggregation_options")
}

model ActualDisaggregation {
  id               String               @id @default(uuid())
  actualId         String
  indicatorId      String
  disaggregationId String
  optionId         String
  value            Float?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  actual         IndicatorActual      @relation(fields: [actualId],         references: [id], onDelete: Cascade)
  indicator      Indicator            @relation(fields: [indicatorId],      references: [id])
  disaggregation Disaggregation       @relation(fields: [disaggregationId], references: [id])
  option         DisaggregationOption @relation(fields: [optionId],         references: [id])

  @@unique([actualId, disaggregationId, optionId])
  @@map("actual_disaggregations")
}

// ── Theory of Change ──────────────────────────────────────────────────────────
model TheoryOfChange {
  id          String   @id @default(uuid())
  level       String
  referenceId String
  narrative   String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User?           @relation(fields: [createdById], references: [id])
  assumptions ToCAssumption[]
  risks       ToCRisk[]

  @@unique([level, referenceId])
  @@map("theory_of_change")
}

model ToCAssumption {
  id        String         @id @default(uuid())
  tocId     String
  text      String
  category  String?
  orderNo   Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  toc TheoryOfChange @relation(fields: [tocId], references: [id], onDelete: Cascade)

  @@map("toc_assumptions")
}

model ToCRisk {
  id          String         @id @default(uuid())
  tocId       String
  title       String
  description String?
  likelihood  String?
  impact      String?
  mitigation  String?
  orderNo     Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  toc TheoryOfChange @relation(fields: [tocId], references: [id], onDelete: Cascade)

  @@map("toc_risks")
}

// ── MTEF (Medium Term Expenditure Framework) ──────────────────────────────────
model MtefBudget {
  id             String   @id @default(uuid())
  activityId     String
  institutionId  String
  year1          String
  year2          String
  year3          String
  year1Budget    Float    @default(0)
  year2Budget    Float    @default(0)
  year3Budget    Float    @default(0)
  totalBudget    Float    @default(0)
  fundingSource  String?
  programCode    String?
  subProgramCode String?
  currency       String   @default("TZS")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  activity    Activity    @relation(fields: [activityId],    references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id])

  @@unique([activityId, institutionId])
  @@map("mtef_budgets")
}

// ── External Integrations (DHIS2, KoboToolbox, PLANREP, IFMS) ────────────────
model ExternalIntegration {
  id                String    @id @default(uuid())
  system            String    @unique  // 'dhis2'|'kobotoolbox'|'planrep'|'ifms'
  displayName       String
  baseUrl           String?
  apiKey            String?
  username          String?
  passwordEncrypted String?
  clientId          String?   // for OAuth-based systems
  clientSecret      String?
  isEnabled         Boolean   @default(false)
  lastSyncAt        DateTime?
  lastSyncStatus    String?   // 'success'|'failed'|'partial'
  lastSyncMessage   String?
  syncCount         Int       @default(0)
  syncConfig        Json?     // field mappings, filters, etc.
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  syncLogs ExternalSyncLog[]

  @@map("external_integrations")
}

model ExternalSyncLog {
  id            String   @id @default(uuid())
  integrationId String
  status        String   // 'success'|'failed'|'partial'
  message       String?
  recordsSynced Int      @default(0)
  errors        Json?
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  integration ExternalIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@map("external_sync_logs")
}

// ── Automated Email Reports ───────────────────────────────────────────────────
model EmailSchedule {
  id          String    @id @default(uuid())
  name        String
  recipients  String[]
  reportType  String    // 'weekly_summary'|'monthly_performance'|'indicator_status'
  cronExpr    String    // cron expression e.g. '0 8 * * 1'
  isActive    Boolean   @default(true)
  lastSentAt  DateTime?
  params      Json?     // additional filters/config
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("email_schedules")
}

// ── SMS Logs ──────────────────────────────────────────────────────────────────
model SmsLog {
  id        String   @id @default(uuid())
  to        String
  message   String
  status    String   // 'sent'|'failed'|'queued'
  provider  String   @default("africas_talking")
  messageId String?
  cost      Float?
  error     String?
  sentAt    DateTime @default(now())

  @@map("sms_logs")
}

// ── Custom Form Designer ──────────────────────────────────────────────────────
model CustomForm {
  id          String   @id @default(uuid())
  name        String
  description String?
  indicatorId String?
  schema      Json     // array of field definitions
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User                 @relation(fields: [createdById], references: [id])
  submissions CustomFormResponse[]

  @@map("custom_forms")
}

model CustomFormResponse {
  id            String           @id @default(uuid())
  formId        String
  institutionId String?
  submittedById String
  data          Json
  period        ReportingPeriod?
  fiscalYear    String?
  latitude      Float?
  longitude     Float?
  status        SubmissionStatus @default(draft)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  form        CustomForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  submittedBy User         @relation(fields: [submittedById], references: [id])
  institution Institution? @relation(fields: [institutionId], references: [id])

  @@map("custom_form_responses")
}

// ── Account Requests (from login page) ───────────────────────────────────────
model UserRequest {
  id              String    @id @default(uuid())
  name            String
  email           String
  institution     String
  role            String    @default("data_collector")
  reason          String?
  status          String    @default("pending")  // pending | approved | rejected
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reviewedBy User? @relation("RequestReviewedBy", fields: [reviewedById], references: [id])

  @@map("user_requests")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model SwotEntry {
  id            String       @id @default(uuid())
  category      SwotCategory
  area          String
  description   String
  impact        String?
  institutionId String?
  fiscalYear    String
  createdById   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  institution Institution? @relation(fields: [institutionId], references: [id])
  createdBy   User          @relation(fields: [createdById], references: [id])

  @@map("swot_entries")
}

// ── Automated Insight Engine ──────────────────────────────────────────────────
model SystemInsight {
  id             String   @id @default(uuid())
  // Context: what this insight is about
  scope          String   // 'submission' | 'indicator' | 'national' | 'institution'
  indicatorId    String?
  actualId       String?
  institutionId  String?
  fiscalYear     String?
  period         String?
  // Insight content
  insightType    String   // 'achievement' | 'trend' | 'anomaly' | 'forecast' | 'risk' | 'lagging'
  severity       String   @default("info")  // 'info' | 'warning' | 'critical'
  headline       String   // Short bold line e.g. "Below target by 23%"
  narrative      String   // Full plain-language sentence(s)
  value          Float?   // The actual value referenced
  target         Float?   // The target referenced
  previousValue  Float?   // Last period value (for trend/comparison)
  changePercent  Float?   // % change vs previous period
  isRead         Boolean  @default(false)
  isDismissed    Boolean  @default(false)
  generatedAt    DateTime @default(now())
  expiresAt      DateTime?

  indicator   Indicator?       @relation(fields: [indicatorId],    references: [id], onDelete: Cascade)
  actual      IndicatorActual? @relation(fields: [actualId],        references: [id], onDelete: Cascade)
  institution Institution?     @relation(fields: [institutionId],   references: [id])

  @@index([scope, fiscalYear, period])
  @@index([indicatorId])
  @@index([actualId])
  @@index([institutionId, fiscalYear])
  @@map("system_insights")
}

// ═════════════════════════════════════════════════════════════════════════════════
// ── DIRA YA TAIFA 2050 STRATEGIC INTEGRATION (7 Flagships & Automation Framework) ──
// ═════════════════════════════════════════════════════════════════════════════════

enum ContributionType {
  primary
  secondary
  supporting
}

enum DataSourceType {
  manual_entry
  auto_calculated
  imported
}

enum AggregationMethod {
  sum
  average
  weighted_average
  count
  percentage
  formula
}

enum EntityStatus {
  draft
  submitted
  validated
  final
  archived
}

enum ObjectiveStatus {
  on_track
  at_risk
  off_track
  completed
}

// Strategic Objectives (7 Flagships from Dira ya Taifa 2050)
model StrategicObjectiveDira {
  id              String     @id @default(uuid())
  code            String     @unique
  name            String     @db.VarChar(255)
  description     String?
  vision_statement String?
  priority_level  Int        @db.SmallInt
  flagship_badge  String?
  key_focus_areas Json?      // JSON array of focus areas
  geographical_focus String?
  estimated_investment_usd Decimal @default(0)
  target_completion_year Int?
  status          String     @default("active") @db.VarChar(50) // active|archived|planned
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  created_by      String?
  updated_by      String?

  projectObjectives ProjectStrategicObjective[]
  progressSnapshots StrategicObjectiveProgress[]

  @@index([status])
  @@index([priority_level])
  @@map("strategic_objectives_dira")
}

// Foundational Reforms
model FoundationalReform {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String   @db.VarChar(255)
  description     String?
  institution_responsible String?
  issue_addressed String?
  recommendations String?
  status          String   @default("active") @db.VarChar(50) // active|completed|archived
  target_completion_date DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([status])
  @@map("foundational_reforms")
}

// Junction: Projects ↔ Strategic Objectives (Many-to-Many)
model ProjectStrategicObjective {
  id                  String     @id @default(uuid())
  projectId           String
  strategic_objective_id String
  contribution_type   String     @db.VarChar(50) @default("primary") // primary|secondary|supporting
  weighting           Decimal    @default(100.00)
  status              String     @default("active")
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  project              Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  strategicObjective   StrategicObjectiveDira @relation(fields: [strategic_objective_id], references: [id], onDelete: Restrict)

  @@unique([projectId, strategic_objective_id])
  @@index([strategic_objective_id])
  @@index([projectId])
  @@map("project_strategic_objectives")
}

// Activity Indicator Mappings (defines how activities feed indicators)
model ActivityIndicatorMapping {
  id                   String     @id @default(uuid())
  activity_id          String
  indicator_id         String
  contribution_type    String     @db.VarChar(50) // direct|indirect|supporting
  aggregation_method   String     @db.VarChar(50) // sum|average|weighted_average|count|percentage|formula
  weighting            Decimal    @default(100.00)
  calculation_formula  String?
  data_element_key     String?
  enabled              Boolean    @default(true)
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt

  activity Activity @relation("ActivityToIndicatorMappings", fields: [activity_id], references: [id], onDelete: Cascade)
  indicator Indicator @relation("IndicatorToActivityMappings", fields: [indicator_id], references: [id], onDelete: Restrict)

  @@unique([activity_id, indicator_id])
  @@index([indicator_id])
  @@index([enabled])
  @@map("activity_indicator_mappings")
}

// Performance Data (auto-calculated indicator values)
model PerformanceData {
  id                      String     @id @default(uuid())
  indicator_id            String
  period                  String     @db.VarChar(20)
  period_start            DateTime
  period_end              DateTime
  actual_value            Decimal?
  previous_value          Decimal?
  target_value            Decimal?
  baseline_value          Decimal?
  achievement_percentage  Decimal?
  data_source             String     @db.VarChar(50) // manual_entry|auto_calculated|imported
  source_activities       Json?      // JSON array of activity IDs that contributed
  calculation_formula_used String?
  confidence_score        Decimal    @default(100)
  status                  String     @db.VarChar(50) @default("draft") // draft|submitted|validated|final|archived
  created_at              DateTime   @default(now())
  created_by              String?
  updated_at              DateTime   @updatedAt
  updated_by              String?

  indicator Indicator @relation("IndicatorPerformanceData", fields: [indicator_id], references: [id], onDelete: Cascade)

  @@index([period_start, period_end])
  @@index([indicator_id, period_start])
  @@index([data_source])
  @@index([status])
  @@map("performance_data")
}

// Project Progress Snapshots
model ProjectProgressSnapshot {
  id                          String   @id @default(uuid())
  project_id                  String
  snapshot_date               DateTime @default(now())
  overall_completion_percentage Int?
  status                      String   @db.VarChar(50) // in_progress|tracking|on_schedule|at_risk|delayed
  activities_completed        Int?
  activities_total            Int?
  indicators_on_track         Int?
  indicators_total            Int?
  forecasted_completion_date  DateTime?
  created_at                  DateTime @default(now())

  project Project @relation("ProjectProgressSnapshots", fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id, snapshot_date])
  @@map("project_progress_snapshots")
}

// Strategic Objective Progress (aggregated)
model StrategicObjectiveProgress {
  id                      String   @id @default(uuid())
  strategic_objective_id  String
  snapshot_date           DateTime @default(now())
  overall_achievement_percentage Int?
  status                  String   @db.VarChar(50) // on_track|at_risk|off_track|completed
  projects_active         Int?
  projects_on_track       Int?
  projects_at_risk        Int?
  key_indicators_achieved Int?
  key_indicators_total    Int?
  flagged_risks           Json?    // JSON array of risk descriptions
  last_updated_at         DateTime @default(now())

  strategicObjective StrategicObjectiveDira @relation(fields: [strategic_objective_id], references: [id], onDelete: Cascade)

  @@index([strategic_objective_id, snapshot_date])
  @@map("strategic_objective_progress")
}

// Audit Trail for Automatic Updates
model AuditTrailDira {
  id                  String   @id @default(uuid())
  entity_type         String   @db.VarChar(50) // indicator|project_progress|objective_progress|activity
  entity_id           String
  change_type         String   @db.VarChar(50) // created|updated|auto_calculated|rolled_back
  previous_value      String?
  new_value           String?
  reason_code         String   @db.VarChar(100) // activity_completion|manual_edit|recalculation
  triggered_by_id     String?
  triggered_by_type   String   @db.VarChar(50) // activity|user|system
  correlation_id      String?  // Links related changes
  metadata            Json?
  created_at          DateTime @default(now())
  created_by          String?

  @@index([entity_type, entity_id])
  @@index([triggered_by_id, triggered_by_type])
  @@index([correlation_id])
  @@index([created_at])
  @@map("audit_trail_dira")
}

// Indicator Calculation Rules
model IndicatorCalculationRule {
  id                          String   @id @default(uuid())
  rule_name                   String   @db.VarChar(255)
  indicator_id                String
  activity_selection_criteria Json?    // JSON object with filters
  aggregation_logic           String?
  time_window                 Int      @default(90) // Days to look back
  enabled                     Boolean  @default(true)
  status                      String   @default("active")
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  indicator Indicator @relation("IndicatorCalculationRules", fields: [indicator_id], references: [id], onDelete: Cascade)

  @@index([indicator_id])
  @@index([enabled])
  @@map("indicator_calculation_rules")
}

// ═════════════════════════════════════════════════════════════════════════════════
// Update existing relations to support strategic integration
// ═════════════════════════════════════════════════════════════════════════════════

// These relations need to be added to existing models:
// Activity: activityToIndicatorMappings ActivityIndicatorMapping[] @relation("ActivityToIndicatorMappings")
// Indicator: activityToIndicatorMappings ActivityIndicatorMapping[] @relation("IndicatorToActivityMappings")
//            performanceData PerformanceData[] @relation("IndicatorPerformanceData")
//            calculationRules IndicatorCalculationRule[] @relation("IndicatorCalculationRules")
// Project: progressSnapshots ProjectProgressSnapshot[] @relation("ProjectProgressSnapshots")
