# ══════════════════════════════════════════════════════════════════
# MIT M&E System — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control
# ══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/mit_mes"

# ── JWT Secrets (generate strong random strings — min 64 chars) ───
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-minimum-64-characters-long-replace-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-minimum-64-characters-long-replace-this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server Ports ──────────────────────────────────────────────────
PORT=5000            # HTTP redirect port
HTTPS_PORT=5443      # Main HTTPS port

# ── Environment ───────────────────────────────────────────────────
NODE_ENV="production"

# ── App URL (used for password reset email links) ─────────────────
APP_URL="https://YOUR_SERVER_IP:5443"

# ── Email / SMTP (optional — leave blank to log emails to console) ─
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="MIT M&E System <noreply@mit.go.tz>"
