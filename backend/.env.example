# ══════════════════════════════════════════════════════════════════
# MIT M&E System — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control
# ══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/mit_mes"

# ── JWT Secrets (generate strong random strings — min 64 chars) ───
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-minimum-64-characters-long-replace-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-minimum-64-characters-long-replace-this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server Ports ──────────────────────────────────────────────────
PORT=5000            # HTTP redirect port
HTTPS_PORT=5443      # Main HTTPS port

# ── Environment ───────────────────────────────────────────────────
NODE_ENV="production"

# ── App URL (used for password reset email links) ─────────────────
APP_URL="https://YOUR_SERVER_IP:5443"

# ── Credential Encryption (REQUIRED for external integrations) ────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-encryption-key-replace-this-value-before-deploy"

# ── Security Tuning ───────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5          # Failed attempts before lockout (default: 5)
LOGIN_LOCKOUT_MINUTES=30      # Lockout duration in minutes (default: 30)
DB_POOL_SIZE=10               # Prisma connection pool size (default: 10)

# ── CORS Tunnels (development/demo only — never set true in production) ──
# ALLOW_TUNNEL_CORS=true      # Enables *.trycloudflare.com, *.lhr.life, etc.

# ── Email / SMTP (optional — leave blank to suppress emails) ─────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="MIT M&E System <noreply@mit.go.tz>"
