# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment variables (NEVER commit real secrets) ─────────────────────────
.env
.env.local
.env.production
backend/.env
frontend/.env

# ── Build outputs ─────────────────────────────────────────────────────────────
frontend/dist/
frontend/dist-ssr/
*.local

# ── Uploads (user-uploaded files — too large for git) ─────────────────────────
backend/uploads/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── PM2 ───────────────────────────────────────────────────────────────────────
.pm2/

# ── SSL certificates (regenerate on each server) ─────────────────────────────
backend/certs/cert.pem
backend/certs/key.pem

# ── Prisma generated client (auto-generated) ──────────────────────────────────
backend/node_modules/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Claude Code (machine-specific paths — not useful to other developers) ─────
.claude/

# ── Puppeteer / screenshots (dev tools, not source code) ─────────────────────
manual_screenshots/
node_modules/
capture_screenshots.js
build_manual.py

# ── Prisma migrations lock (keep migration files but not lock) ────────────────
backend/prisma/migrations/**/migration_lock.toml
